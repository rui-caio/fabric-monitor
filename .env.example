TENANT_ID=
CAPACITY_ID=
METRICS_WS=
METRICS_DS=
PORT=8765
ORG_NAME=

# Auth: "public" (default) = device code, interactive user (works with Power BI admin, no app secret).
#        "client_secret" = service principal: set CLIENT_ID + CLIENT_SECRET (and application permissions
#        on the app registration, admin-consented, for Power BI and optionally Fabric).
# For public, CLIENT_ID is optional (defaults to the built-in PBI public client for device sign-in).
# AUTH_TYPE=public
# AUTH_TYPE=client_secret
# CLIENT_ID=
# CLIENT_SECRET=

# How dates/times are shown in the UI (API timestamps are UTC).
# Best: IANA timezone — follows daylight saving automatically (e.g. Portugal: Europe/Lisbon).
# DISPLAY_TIMEZONE=Europe/Lisbon
#
# Alternative: fixed offset from UTC in hours (no DST; use 0 or 1 only if you must).
# Ignored if DISPLAY_TIMEZONE is set.
# DISPLAY_UTC_OFFSET_HOURS=1
